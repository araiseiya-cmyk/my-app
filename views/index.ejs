<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>ユーザー一覧</title>
</head>
<body>
  <h1>ユーザー一覧</h1>
  <ul>
    <% users.forEach(user => { %>
      <li>
        <%= user.name %> 
        （<%= (user.age !== null && user.age !== undefined) ? user.age : '未設定' %> 歳）
      </li>
    <% }) %>
  </ul>

  <hr>

  <h2>ユーザー追加</h2>
  <form action="/users" method="post">
    <div>
      <label>名前：</label>
      <input type="text" name="name" placeholder="名前を入力" required>
    </div>
    <div style="margin-top: 10px;">
      <label>年齢：</label>
      <input type="number" name="age" placeholder="年齢を入力">
    </div>
    <button type="submit" style="margin-top: 10px;">追加する</button>
  </form>
</body>
</html>
